# ---- App ----
ENVIRONMENT=development
PORT=8000
CLIENT_ORIGIN=http://localhost:3000

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_architect

# ---- JWT / Tokens ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
ACCESS_TOKEN_SECRET=change-me-access-secret
REFRESH_TOKEN_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
RESET_TOKEN_TTL_MINUTES=30
VERIFY_TOKEN_TTL_HOURS=24

# ---- Cookies ----
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=

# ---- Mail (SMTP) ----
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=AI Software Architect
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_SUPPRESS_SEND=true

# ---- Uploads ----
UPLOAD_DIR=./uploads
MAX_AVATAR_BYTES=2097152

# ---- Rate limiting ----
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_FORGOT=3/minute
